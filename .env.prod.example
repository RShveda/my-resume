# PostgreSQL
POSTGRES_DB=resume
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Django
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ALLOWED_ORIGINS=http://your-domain.com:3000,https://your-domain.com

# Frontend (build arg, not runtime)
VITE_API_URL=http://your-domain.com:8000/api
